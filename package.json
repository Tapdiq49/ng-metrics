{
  "name": "ng-metrics",
  "version": "1.10.0",
  "description": "CLI tool for Angular metrics",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tapdiq49/ng-metrics"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://github.com/Tapdiq49/ng-metrics/blob/main/README.md",
  "main": "dist/index.js",
  "bin": {
    "ng-metrics": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-templates",
    "copy-templates": "node scripts/copy-templates.js",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "test": "vitest run src"
  },
  "keywords": [
    "angular",
    "metrics",
    "cli",
    "code-analysis",
    "static-analysis",
    "health-score",
    "bundle-analysis"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "handlebars": "^4.7.9",
    "ora": "^5.4.1",
    "ts-morph": "^28.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/handlebars": "^4.0.40",
    "@types/node": "^25.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
